# BDDK MCP Server - Environment Variables
# Copy this file to .env and fill in your values.

# PostgreSQL connection
BDDK_DATABASE_URL=postgresql://user:password@localhost:5432/bddk

# Connection pool
BDDK_PG_POOL_MIN=2
BDDK_PG_POOL_MAX=10

# Embedding model (offline-first: set path to pre-downloaded model)
# BDDK_EMBEDDING_MODEL_PATH=/path/to/local/model
# BDDK_EMBEDDING_MODEL=intfloat/multilingual-e5-base

# Cache
# BDDK_CACHE_TTL=3600
# BDDK_SEARCH_CACHE_TTL=300

# Sync
# BDDK_AUTO_SYNC=false
# BDDK_SYNC_CONCURRENCY=5

# Expose operator/admin tools (health_check, bddk_metrics, sync_bddk_documents,
# refresh_bddk_cache, backfill_*, document_health, document_quality_report,
# document_store_stats, bddk_cache_status, trigger_startup_sync). Leave unset
# or "false" for end-user deployments — the server will then expose only the
# search, retrieval, bulletin, and analytics tools.
# BDDK_ADMIN_TOOLS=false
