# Copy to .env on the OCI VM and fill in real values.

# Public hostname pointed at this VM's IP. Caddy will get a Let's Encrypt cert for it.
DOMAIN=bddk.example.com

# Postgres credentials (used by both db and bddk services)
POSTGRES_USER=bddk
POSTGRES_PASSWORD=change-me-to-something-strong
POSTGRES_DB=bddk

# Set to true ONLY for the very first boot to seed the DB from seed_data/.
# After the first successful run, flip back to false.
BDDK_AUTO_SYNC=false
